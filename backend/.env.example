# ─── Server ───────────────────────────────────────────────
PORT=8080
FRONTEND_URL=http://localhost:5173

# ─── SQLite ───────────────────────────────────────────────
# Path to the SQLite database file (created automatically on first run)
DATABASE_PATH=./portfolio.db

# ─── Auth ─────────────────────────────────────────────────
# Secret key for signing JWTs — use a long random string in production
JWT_SECRET=change-me-to-something-long-and-random

# Password for the owner/secret page (same as frontend constant)
OWNER_PASSWORD=inkandashes

# ─── Cloudinary ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
