rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Works — anyone can read published, only owner can write
    match /works/{workId} {
      allow read: if resource.data.status == 'published';
      allow read, write: if request.auth != null;

      // Chapters — public reads allowed (client filters to published only)
      match /chapters/{chapterId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // Journal — anyone can read published, only owner can write
    match /journal/{id} {
      allow read: if resource.data.published == true;
      allow read, write: if request.auth != null;
    }

    // Config/profile — anyone can read, only owner can write
    match /config/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Private journal — owner only, never public
    match /private/{id} {
      allow read, write: if request.auth != null;
    }

    // Letters to future — owner only
    match /letters/{id} {
      allow read, write: if request.auth != null;
    }
  }
}
